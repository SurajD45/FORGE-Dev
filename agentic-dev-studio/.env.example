# ── LLM API Keys ─────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_KEY_2=friend1-key
GROQ_API_KEY_3=friend2-key

# ── Supabase ─────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Redis ────────────────────────────────────────
# Docker Compose (local dev): use the service name 'redis'
REDIS_URL=redis://redis:6379/0

# Upstash (cloud production): uncomment and use your Upstash URL
# REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379

# ── Telemetry (disable) ─────────────────────────
CREWAI_DISABLE_TELEMETRY=true
OTEL_SDK_DISABLED=true

# ── Schema Migration ────────────────────────────
# Set to true to auto-run DB migrations on startup
AUTO_MIGRATE_DB=false